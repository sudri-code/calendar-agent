# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
BOT_WEBHOOK_SECRET=your_webhook_secret_here
BOT_WEBHOOK_URL=https://yourdomain.com/webhook/telegram

# Database
DATABASE_URL=postgresql+asyncpg://calendar_bot:changeme@postgres:5432/calendar_bot
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# OpenRouter LLM
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3-haiku

# Microsoft OAuth
MS_CLIENT_ID=your_microsoft_client_id_here
MS_CLIENT_SECRET=your_microsoft_client_secret_here
MS_REDIRECT_URI=https://yourdomain.com/api/v1/accounts/oauth/callback
MS_TENANT_ID=common
MS_SCOPES=User.Read offline_access Calendars.ReadWrite Calendars.ReadWrite.Shared Contacts.Read

# Security
ENCRYPTION_KEY=your_fernet_key_here_generate_with_cryptography
INTERNAL_API_KEY=your_internal_api_key_here

# Service URLs (internal)
API_BASE_URL=http://api:8000
BOT_BASE_URL=http://bot:8080

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
