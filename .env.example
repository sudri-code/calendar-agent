# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
BOT_WEBHOOK_SECRET=your_webhook_secret_here
BOT_WEBHOOK_URL=https://yourdomain.com/webhook/telegram

# Database
DATABASE_URL=postgresql+asyncpg://calendar_bot:changeme@postgres:5432/calendar_bot
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# OpenRouter LLM
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-3-haiku

# EWS / on-premises Exchange
# Credentials are entered per-user via the bot interface (/accounts).
# EWS_VERIFY_SSL=true   # set to false for self-signed corporate certificates
# EWS_TIMEZONE=Europe/Moscow  # IANA timezone for calendar display (default: Europe/Moscow)

# Security
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here
INTERNAL_API_KEY=your_internal_api_key_here

# Service URLs (internal Docker network)
API_BASE_URL=http://api:8000
BOT_BASE_URL=http://bot:8080

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO
